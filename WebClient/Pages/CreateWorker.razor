@page "/create-worker"
@using Common.Constants

@inject AuthService AuthService
@inject ApiService ApiService
@inject NavigationManager Navigation

<h3>Create Worker</h3>

@if (role != UserRoleConstants.ADMIN_ROLE)
{
    <p style="color:red">Only Admin can access this page.</p>
}
else
{
    <div>
        <label>Worker username</label>
        <br />
        <input @bind="request.UserName" />
    </div>

    <br />

    <div>
        <label>Worker password</label>
        <br />
        <input type="password" @bind="request.Password" />
    </div>

    <br />

    <button @onclick="CreateWorkerAsync">Create Worker</button>
}

@if (!string.IsNullOrWhiteSpace(message))
{
    <p style="color:green">@message</p>
}

@if (!string.IsNullOrWhiteSpace(error))
{
    <p style="color:red">@error</p>
}

@code {
    private string? role;
    private CreateAccountRequest request = new();
    private string? message;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        role = await AuthService.GetRoleAsync();
    }

    private async Task CreateWorkerAsync()
    {
        message = null;
        error = null;

        try
        {
            var result = await ApiService.CreateWorkerAsync(request);

            message = $"Worker '{result.UserName}' created with role '{result.Role}'.";

            request = new();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }
}