@page "/create-request"
@using Common.Constants

@inject AuthService AuthService
@inject ApiService ApiService

<h3>Create Request</h3>

@if (role != UserRoleConstants.USER_ROLE)
{
    <p style="color:red">Only User can create requests.</p>
}
else
{
    <div>
        <label>Name</label>
        <br />
        <input @bind="request.Name" />
    </div>

    <br />

    <div>
        <label>Description</label>
        <br />
        <textarea @bind="request.Description"></textarea>
    </div>

    <br />

    <button @onclick="CreateRequestAsync">Create Request</button>
}

@if (!string.IsNullOrWhiteSpace(message))
{
    <p style="color:green">@message</p>
}

@if (!string.IsNullOrWhiteSpace(error))
{
    <p style="color:red">@error</p>
}

@code {
    private string? role;
    private CreateRequestRequest request = new();
    private string? message;
    private string? error;

    protected override async Task OnInitializedAsync()
    {
        role = await AuthService.GetRoleAsync();
    }

    private async Task CreateRequestAsync()
    {
        message = null;
        error = null;

        try
        {
            var result = await ApiService.CreateRequestAsync(request);

            message = $"Request '{result.Name}' created successfully.";

            request = new();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }
}