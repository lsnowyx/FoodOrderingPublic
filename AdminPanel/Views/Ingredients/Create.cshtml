@model AdminPanel.Models.Ingredient.IngredientViewModel

@{
    ViewData["Title"] = "Create Ingredient";
}

<h3>Create Ingredient</h3>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <div class="form-group">
        @Html.LabelFor(m => m.Name)
        @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.AllergenInfo)
        @Html.TextAreaFor(m => m.AllergenInfo, new { @class = "form-control", rows = 3 })
        @Html.ValidationMessageFor(m => m.AllergenInfo, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.BaseUnit)
        @Html.TextBoxFor(
            m => m.BaseUnit,
            new { @class = "form-control", placeholder = "Examples: 1 piece, 100g, 1 liter" })
        @Html.ValidationMessageFor(m => m.BaseUnit, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.UnitCost)
        @Html.TextBoxFor(
            m => m.UnitCost,
            new { @class = "form-control", type = "number", min = "0", step = "0.01" })
        @Html.ValidationMessageFor(m => m.UnitCost, "", new { @class = "text-danger" })
    </div>
    <div class="form-group">
        @Html.LabelFor(m => m.CaloriesPerUnit)
        @Html.TextBoxFor(m => m.CaloriesPerUnit, new { @class = "form-control", type = "number" })
        @Html.ValidationMessageFor(m => m.CaloriesPerUnit, "", new { @class = "text-danger" })
    </div>
    <button class="btn btn-primary">Create</button>
    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
}
