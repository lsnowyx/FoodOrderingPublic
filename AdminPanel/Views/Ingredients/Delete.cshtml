@model AdminPanel.Models.Ingredient.IngredientViewModel

@{
    ViewData["Title"] = "Delete Ingredient";
}

<h3>Delete Ingredient</h3>

<div class="alert alert-warning">Are you sure you want to delete this ingredient?</div>

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Allergen Info</dt>
    <dd class="col-sm-10">@Model.AllergenInfo</dd>

    <dt class="col-sm-2">Calories</dt>
    <dd class="col-sm-10">@Model.CaloriesPerUnit</dd>
</dl>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
</form>
