@model AdminPanel.Models.MenuItem.MenuItemViewModel

@{
    ViewData["Title"] = "Create Menu Item";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container .select2-selection--single {
            min-height: 38px;
        }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 36px;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            min-height: 36px;
        }
    </style>
}

<h3>Create Menu Item</h3>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <div class="form-group mb-2">
        @Html.LabelFor(m => m.Name)
        @Html.TextBoxFor(m => m.Name, new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Name, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-2">
        @Html.LabelFor(m => m.Description)
        @Html.TextAreaFor(m => m.Description, new { @class = "form-control", rows = 3 })
        @Html.ValidationMessageFor(m => m.Description, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-2">
        @Html.LabelFor(m => m.Price)
        @Html.TextBoxFor(m => m.Price, new { @class = "form-control", type = "number", step = "0.01" })
        @Html.ValidationMessageFor(m => m.Price, "", new { @class = "text-danger" })
    </div>
    <div class="form-group mb-2">
        @Html.LabelFor(m => m.CategoryId, "Category")
        <select asp-for="CategoryId"
                id="categorySelect"
                class="form-control js-category-lookup"
                data-lookup-url="@Url.Action("CategoryLookup", "MenuItems")"
                data-placeholder="Search categories..."
                required>
            <option></option>
            @if (Model.CategoryId != Guid.Empty && !string.IsNullOrWhiteSpace(Model.CategoryName))
            {
                <option value="@Model.CategoryId" selected>@Model.CategoryName</option>
            }
        </select>
        @Html.ValidationMessageFor(m => m.CategoryId, "", new { @class = "text-danger" })
    </div>
    <div class="form-check mb-3">
        @Html.CheckBoxFor(m => m.IsAvailable, new { @class = "form-check-input" })
        @Html.LabelFor(m => m.IsAvailable, new { @class = "form-check-label" })
    </div>
    <button class="btn btn-primary">Create</button>
    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        (function () {
            const $categorySelect = $('#categorySelect');
            if (!$categorySelect.length) {
                return;
            }

            $categorySelect.select2({
                width: '100%',
                placeholder: $categorySelect.data('placeholder'),
                allowClear: true,
                minimumInputLength: 2,
                ajax: {
                    url: $categorySelect.data('lookup-url'),
                    dataType: 'json',
                    delay: 300,
                    data: function (params) {
                        return {
                            searchTerm: params.term || '',
                            page: params.page || 1
                        };
                    },
                    processResults: function (data) {
                        return data;
                    },
                    cache: true
                }
            });
        })();
    </script>
}
