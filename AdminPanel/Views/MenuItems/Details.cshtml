@model AdminPanel.Models.MenuItem.MenuItemDetailsViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Menu Item Details";
}

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <style>
        .select2-container .select2-selection--single {
            min-height: 38px;
        }

        .select2-container--default .select2-selection--single .select2-selection__rendered {
            line-height: 36px;
        }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            min-height: 36px;
        }
    </style>
}

<h3>@Model.Item.Name</h3>

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<div class="mb-3">
    <strong>Selling price:</strong> @Model.Item.Price.ToString("C")
</div>
<div class="mb-3">
    <strong>Restaurant cost:</strong> @Model.Item.RestaurantCost.ToString("C")
</div>
<div class="mb-3">
    <strong>Total calories:</strong> @Model.Item.TotalCalories.ToString("0.##") kcal
</div>
<div class="mb-3">
    <strong>Category:</strong> @Model.Item.CategoryName
</div>
<div class="mb-3">
    <strong>Availability:</strong>
    @if (Model.Item.IsAvailable)
    {
        <span class="badge bg-success">Available</span>
    }
    else
    {
        <span class="badge bg-secondary">Unavailable</span>
    }
</div>
<div class="mb-3">
    <strong>Description:</strong>
    <p>@Model.Item.Description</p>
</div>
<h4>Ingredients</h4>

@if (Model.Ingredients != null && Model.Ingredients.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Ingredient</th>
                <th>Base unit</th>
                <th>Unit cost</th>
                <th>Allergen</th>
                <th>Calories</th>
                <th>Quantity</th>
                <th>Line cost</th>
                <th>Line calories</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var ing in Model.Ingredients)
        {
            <tr>
                <td>@ing.IngredientName</td>
                <td>@ing.BaseUnit</td>
                <td>@ing.UnitCost.ToString("C")</td>
                <td>@ing.AllergenInfo</td>
                <td>@(ing.CaloriesPerUnit?.ToString() ?? "-")</td>
                <td>
                    <form asp-action="UpdateIngredient" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@Model.Item.Id" />
                        <input type="hidden" name="ingredientId" value="@ing.IngredientId" />
                        <input name="quantity"
                               type="number"
                               min="0.01"
                               step="0.01"
                               required
                               class="form-control d-inline"
                               style="width:150px;display:inline-block"
                               value="@ing.Quantity.ToString(CultureInfo.InvariantCulture)" />
                        <button class="btn btn-sm btn-primary ms-2" type="submit">Save</button>
                    </form>
                </td>
                <td>@ing.LineCost.ToString("C")</td>
                <td>@ing.LineCalories.ToString("0.##") kcal</td>
                <td>
                    <form asp-action="DeleteIngredient" method="post" onsubmit="return confirm('Remove ingredient?');">
                        <input type="hidden" name="id" value="@Model.Item.Id" />
                        <input type="hidden" name="ingredientId" value="@ing.IngredientId" />
                        <button class="btn btn-sm btn-danger" type="submit">Remove</button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No ingredients assigned.</p>
}

@if (User.IsInRole(UserRoleConstants.MENU_MANAGER_ROLE))
{
    <h5>Add Ingredient</h5>
    <form asp-action="AddIngredient" method="post" class="row g-2">
        <input type="hidden" name="id" value="@Model.Item.Id" />
        <div class="col-md-5">
            <select id="ingredientSelect"
                    name="ingredientId"
                    class="form-select js-ingredient-lookup"
                    data-lookup-url="@Url.Action("IngredientLookup", "MenuItems")"
                    data-placeholder="Search ingredients..."
                    required>
                <option></option>
            </select>
        </div>
        <div class="col-auto">
            <input name="quantity"
                   type="number"
                   min="0.01"
                   step="0.01"
                   class="form-control"
                   placeholder="Base units (e.g. 0.5, 1, 2)"
                   required />
        </div>
        <div class="col-auto">
            <button class="btn btn-success" type="submit">Add</button>
        </div>
    </form>
}

<h4 id="pictures">Pictures</h4>

<div class="row mb-3">
    <div class="col-12">
        <div class="row">
            @if (Model.Pictures != null && Model.Pictures.Any())
            {
                @foreach (var p in Model.Pictures)
                {
                    <div class="col-sm-6 col-md-4 mb-3">
                        <div class="card h-100">
                            @if (!string.IsNullOrWhiteSpace(p.ImageUrl))
                            {
                                <img src="@p.ImageUrl" class="card-img-top" alt="@p.Caption" style="max-height:180px;object-fit:cover" />
                            }
                            <div class="card-body">
                                <p class="card-text"><strong>@p.Caption</strong></p>
                                <p class="small text-truncate">@p.ImageUrl</p>
                                @if (User.IsInRole(UserRoleConstants.MENU_MANAGER_ROLE))
                                {
                                    <a class="btn btn-sm btn-outline-primary me-2" asp-action="EditPicture" asp-route-id="@Model.Item.Id" asp-route-pictureId="@p.Id">Edit</a>
                                    <form asp-action="DeletePicture" method="post" class="d-inline" onsubmit="return confirm('Delete picture?');">
                                        <input type="hidden" name="id" value="@Model.Item.Id" />
                                        <input type="hidden" name="pictureId" value="@p.Id" />
                                        <button class="btn btn-sm btn-danger" type="submit">Delete</button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12"><p>No pictures.</p></div>
            }
        </div>

        @if (User.IsInRole(UserRoleConstants.MENU_MANAGER_ROLE))
        {
            <h6 class="mt-3">Add Picture</h6>
            <form asp-action="AddPicture" method="post" enctype="multipart/form-data" class="row g-2">
                <input type="hidden" name="id" value="@Model.Item.Id" />
                <div class="col-md-6">
                    <input name="ImageFile" type="file" class="form-control" accept="image/*" required />
                </div>
                <div class="col-md-4">
                    <input name="Caption" class="form-control" placeholder="Caption (optional)" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-success w-100" type="submit">Add</button>
                </div>
            </form>
        }
    </div>
</div>

<p>
    <a class="btn btn-secondary" asp-action="Index">Back to list</a>
    @if (User.IsInRole(UserRoleConstants.MENU_MANAGER_ROLE))
    {
        <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Item.Id">Edit</a>
    }
</p>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        (function () {
            const $ingredientSelect = $('#ingredientSelect');
            if (!$ingredientSelect.length) {
                return;
            }

            function formatIngredient(item) {
                if (item.loading) {
                    return item.text;
                }

                const $container = $('<div>');
                $('<div>').text(item.text).appendTo($container);

                const details = [];
                if (item.allergenInfo) {
                    details.push('Allergen: ' + item.allergenInfo);
                }

                if (item.caloriesPerUnit !== null && item.caloriesPerUnit !== undefined) {
                    details.push(item.caloriesPerUnit + ' calories/unit');
                }

                if (item.baseUnit) {
                    details.push('Base unit: ' + item.baseUnit);
                }

                if (item.unitCost !== null && item.unitCost !== undefined) {
                    details.push('Cost/base unit: ' + item.unitCost);
                }

                if (details.length > 0) {
                    $('<small>').addClass('text-muted').text(details.join(' | ')).appendTo($container);
                }

                return $container;
            }

            $ingredientSelect.select2({
                width: '100%',
                placeholder: $ingredientSelect.data('placeholder'),
                allowClear: true,
                minimumInputLength: 2,
                templateResult: formatIngredient,
                ajax: {
                    url: $ingredientSelect.data('lookup-url'),
                    dataType: 'json',
                    delay: 300,
                    data: function (params) {
                        return {
                            searchTerm: params.term || '',
                            page: params.page || 1
                        };
                    },
                    processResults: function (data) {
                        return data;
                    },
                    cache: true
                }
            });
        })();
    </script>
}
