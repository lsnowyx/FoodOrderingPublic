@model AdminPanel.Models.Order.OrderViewModel?

@{
    ViewData["Title"] = "Deliveries";
}

<h3>Deliveries</h3>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (Model == null)
{
    <p>You have no active delivery.</p>
}
else
{
    var isClosed = Model.Status == "Delivered" || Model.Status == "Cancelled";

    <div class="card mb-3">
        <div class="card-body">
            <h5>Your Delivery</h5>
            <p>
                <strong>Order:</strong> @Model.Id<br />
                <strong>Customer:</strong> @Model.CustomerId<br />
                <strong>Assigned At:</strong> @(Model.AssignedAt?.ToLocalTime().ToString("g") ?? "-")<br />
                <strong>Order Date:</strong> @Model.OrderDate.ToLocalTime().ToString("g")<br />
                <strong>Status:</strong> <span class="badge bg-secondary">@Model.Status</span><br />
                <strong>Payment:</strong> @(Model.IsPaid ? "Paid" : "Unpaid")<br />
                <strong>Delivery Address:</strong> @Model.DeliveryAddress<br />
                <strong>Delivered At:</strong> @(Model.DeliveredAt?.ToLocalTime().ToString("g") ?? "-")
            </p>
        </div>
    </div>

    <div class="mb-3">
        @if (!isClosed && Model.Status != "OutForDelivery")
        {
            <form asp-action="StartDelivery" method="post" class="d-inline">
                <input type="hidden" name="id" value="@Model.Id" />
                <button class="btn btn-primary" type="submit">Start Delivery</button>
                @Html.AntiForgeryToken()
            </form>
        }

        @if (Model.Status == "OutForDelivery")
        {
            <form asp-action="MarkDelivered" method="post" class="d-inline" onsubmit="return confirm('Mark order as delivered?');">
                <input type="hidden" name="id" value="@Model.Id" />
                <button class="btn btn-success" type="submit">Mark Delivered</button>
                @Html.AntiForgeryToken()
            </form>
        }
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5>Payment</h5>
            <form asp-controller="Orders" asp-action="UpdatePayment" method="post" onsubmit="return confirm('Are you sure this order is paid?');">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="isPaid" value="true" />
                <button class="btn btn-sm btn-success" disabled="@(isClosed || Model.IsPaid)">
                    @(Model.IsPaid ? "Paid" : "Mark as Paid")
                </button>
                @Html.AntiForgeryToken()
            </form>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5>Items</h5>
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Quantity</th>
                        <th>Unit Price</th>
                        <th>Line Total</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.MenuItemName</td>
                        <td>@item.Quantity</td>
                        <td>@item.UnitPrice.ToString("C")</td>
                        <td>@item.LineTotal.ToString("C")</td>
                    </tr>
                }
                </tbody>
            </table>

            <div class="mt-2">
                <strong>Total:</strong> @Model.Total.ToString("C")
            </div>
        </div>
    </div>
}
