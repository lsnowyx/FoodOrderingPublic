@model AdminPanel.Models.Order.OrderViewModel?

@{
    ViewData["Title"] = "Deliveries";
}

<h3>Deliveries</h3>

@if (Model == null)
{
    <p>You have no active delivery.</p>
}
else
{
    var isClosed = Model.Status == nameof(Common.Enums.OrderStatus.Delivered)
        || Model.Status == nameof(Common.Enums.OrderStatus.Cancelled);
    var canStartDelivery = !isClosed
        && (Model.Status == nameof(Common.Enums.OrderStatus.Pending)
            || Model.Status == nameof(Common.Enums.OrderStatus.Paid)
            || Model.Status == nameof(Common.Enums.OrderStatus.Preparing));
    var canMarkDelivered = Model.Status == nameof(Common.Enums.OrderStatus.OutForDelivery)
        && Model.IsPaid
        && !isClosed;
    var needsPaymentBeforeFinish = Model.Status == nameof(Common.Enums.OrderStatus.OutForDelivery)
        && !Model.IsPaid
        && !isClosed;
    var isCashPayment = Model.PaymentMethod == nameof(Common.Enums.PaymentMethod.CashOnDelivery);
    var paymentBadgeClass = Model.IsPaid ? "bg-primary" : "bg-secondary";

    <div class="card mb-3">
        <div class="card-body">
            <h5>Your Delivery</h5>
            <p>
                <strong>Order:</strong> @Model.Id<br />
                <strong>Customer:</strong> @Model.CustomerId<br />
                <strong>Assigned At:</strong> @(Model.AssignedAt?.ToLocalTime().ToString("g") ?? "-")<br />
                <strong>Order Date:</strong> @Model.OrderDate.ToLocalTime().ToString("g")<br />
                <strong>Status:</strong> <span class="badge bg-secondary">@Model.Status</span><br />
                <strong>Payment:</strong> @Model.PaymentStatus (@Model.PaymentMethod)<br />
                <strong>Paid At:</strong> @(Model.PaidAt?.ToLocalTime().ToString("g") ?? "-")<br />
                <strong>Delivery Address:</strong> @Model.DeliveryAddress<br />
                <strong>Delivered At:</strong> @(Model.DeliveredAt?.ToLocalTime().ToString("g") ?? "-")
            </p>
        </div>
    </div>

    <div class="mb-3">
        @if (canStartDelivery)
        {
            <form asp-action="StartDelivery" method="post" class="d-inline">
                <input type="hidden" name="id" value="@Model.Id" />
                <button class="btn btn-primary" type="submit">Start Delivery</button>
                @Html.AntiForgeryToken()
            </form>
        }

        @if (canMarkDelivered)
        {
            <form asp-action="MarkDelivered" method="post" class="d-inline" onsubmit="return confirm('Mark order as delivered?');">
                <input type="hidden" name="id" value="@Model.Id" />
                <button class="btn btn-success" type="submit">Mark Delivered</button>
                @Html.AntiForgeryToken()
            </form>
        }
        else if (needsPaymentBeforeFinish)
        {
            <div class="alert alert-warning mt-2 mb-0">
                Payment must be collected/marked before finishing delivery.
            </div>
        }
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5>Payment</h5>
            @if (isCashPayment && !Model.IsPaid && !isClosed)
            {
                <form asp-controller="Orders" asp-action="UpdatePayment" method="post" onsubmit="return confirm('Are you sure this order is paid?');">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <input type="hidden" name="isPaid" value="true" />
                    <button class="btn btn-sm btn-success">Mark as Paid</button>
                    @Html.AntiForgeryToken()
                </form>
            }
            else
            {
                <span class="badge @paymentBadgeClass">@Model.PaymentStatus</span>
            }
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-body">
            <h5>Items</h5>
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th>Quantity</th>
                        <th>Unit Price</th>
                        <th>Line Total</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.MenuItemName</td>
                        <td>@item.Quantity</td>
                        <td>@item.UnitPrice.ToString("C")</td>
                        <td>@item.LineTotal.ToString("C")</td>
                    </tr>
                }
                </tbody>
            </table>

            <div class="mt-2">
                <strong>Total:</strong> @Model.Total.ToString("C")
            </div>
        </div>
    </div>
}
