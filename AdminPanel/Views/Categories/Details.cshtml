@model AdminPanel.Models.Category.CategoryDetailsViewModel

@{
    ViewData["Title"] = "Category Details";
    var menuItems = Model.MenuItems;
    var previousPage = menuItems.Page - 1;
    var nextPage = menuItems.Page + 1;
}

<h3>@Model.Category.Name</h3>

<dl class="row">
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Category.Description</dd>

    <dt class="col-sm-2">Image</dt>
    <dd class="col-sm-10">
        @if (!string.IsNullOrWhiteSpace(Model.Category.ImageUrl))
        {
            <img src="@Model.Category.ImageUrl" alt="@Model.Category.Name" style="max-width:200px;" />
        }
    </dd>
</dl>

<a class="btn btn-secondary" asp-action="Index">Back</a>

<h4 class="mt-4">Menu Items in this Category</h4>

@if (menuItems.Items.Count > 0)
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>Availability</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var m in menuItems.Items)
        {
            <tr>
                <td>@m.Name</td>
                <td>@m.Price.ToString("C")</td>
                <td>
                    @if (m.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Unavailable</span>
                    }
                </td>
                <td>
                    <a class="btn btn-sm btn-info" asp-controller="MenuItems" asp-action="Details" asp-route-id="@m.Id">Details</a>
                    @if (User.IsInRole(UserRoleConstants.MENU_MANAGER_ROLE))
                    {
                        <a class="btn btn-sm btn-warning" asp-controller="MenuItems" asp-action="Edit" asp-route-id="@m.Id">Edit</a>
                    }
                </td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No menu items in this category.</p>
}

@if (menuItems.TotalPages > 0)
{
    <div class="d-flex justify-content-between align-items-center mt-3">
        <div class="text-muted">
            Showing page @menuItems.Page of @menuItems.TotalPages (@menuItems.TotalCount total)
        </div>
        <nav aria-label="Category menu items pagination">
            <ul class="pagination mb-0">
                <li class="page-item @(menuItems.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Details"
                       asp-route-id="@Model.Category.Id"
                       asp-route-page="@previousPage"
                       asp-route-pageSize="@menuItems.PageSize">Previous</a>
                </li>
                <li class="page-item active">
                    <span class="page-link">@menuItems.Page</span>
                </li>
                <li class="page-item @(menuItems.HasNextPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Details"
                       asp-route-id="@Model.Category.Id"
                       asp-route-page="@nextPage"
                       asp-route-pageSize="@menuItems.PageSize">Next</a>
                </li>
            </ul>
        </nav>
    </div>
}
